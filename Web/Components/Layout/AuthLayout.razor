@inherits LayoutComponentBase

<MudContainer MaxWidth="MaxWidth.False" DisableGutters="true" Class="auth-layout-container">
    <MudGrid Spacing="0" Style="height: 100vh;">
        @* Left Hero Section *@
        <MudItem xs="12" md="5" Class="auth-hero-panel d-none d-md-flex">
            <div class="auth-hero-header">
                <div class="auth-brand">
                    <div class="auth-brand-icon">
                        <MudIcon Icon="@Icons.Material.Filled.PieChart" Style="color: #ffffff;" Size="Size.Medium" />
                    </div>
                    <MudText Typo="Typo.h6" Style="color: #ffffff; font-weight: 700; letter-spacing: 0.02em;">PAccountant</MudText>
                </div>
                <MudText Typo="Typo.body2" Class="auth-hero-subtitle">Your account in your hands</MudText>
            </div>

            <div class="auth-hero-wrapper">
                <MudText Typo="Typo.h1" Class="auth-hero-title">Simple.<br/>Secure.<br/>Adaptive.</MudText>
            </div>
        </MudItem>

        @* Right Form Section *@
        <MudItem xs="12" md="7" Class="auth-form-panel">
            <div class="auth-form-content">
                @Body
            </div>
            <div class="auth-footer">
                <MudText Typo="Typo.caption">&copy; 2025 PAccountant. All rights reserved.</MudText>
            </div>
        </MudItem>
    </MudGrid>
</MudContainer>
