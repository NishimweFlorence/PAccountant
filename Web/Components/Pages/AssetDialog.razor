@using Application.DTO
@using Application.Interfaces
@using MudBlazor

@inject IAssetService AssetService
@inject ILookupService LookupService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(IsEdit ? "Edit Asset" : "Add New Asset")
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@Model" OnValidSubmit="OnValidSubmit" FormName="AssetDialogForm">
            <DataAnnotationsValidator />
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField Label="Name" @bind-Value="Model.Name" For="@(() => Model.Name)" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" Label="Type" Value="@Model.Type" For="@(() => Model.Type)" Required="true" Variant="Variant.Outlined" ValueChanged="OnTypeChanged">
                        @foreach (var t in Types)
                        {
                            <MudSelectItem Value="@t">@t</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField Label="Purchase Value" @bind-Value="PurchaseValueProxy" Format="N2" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" Label="Value Change" Value="@Model.ValueChange" For="@(() => Model.ValueChange)" Variant="Variant.Outlined" ValueChanged="OnValueChangeChanged">
                        @foreach (var vc in ValueChanges)
                        {
                            <MudSelectItem Value="@vc">@vc</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField Label="Rate %" @bind-Value="Model.Rate" For="@(() => Model.Rate)" Format="N2" Variant="Variant.Outlined" TextChanged="OnCalculateValues" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" Label="Currency" @bind-Value="Model.Currency" For="@(() => Model.Currency)" Required="true" Variant="Variant.Outlined">
                        @foreach (var c in Currencies)
                        {
                            <MudSelectItem Value="@c">@c</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Purchase Date" @bind-Date="NullablePurchaseDate" Variant="Variant.Outlined" TextChanged="OnCalculateValues" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField Label="Current Value (Calculated)" Value="Model.CurrentValue" ReadOnly="true" Format="N2" Variant="Variant.Filled" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Current Date" Date="DateTime.Today" ReadOnly="true" Variant="Variant.Filled" />
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">@(IsEdit ? "Update" : "Create")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance? MudDialog { get; set; }

    [CascadingParameter] private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState> AuthStateTask { get; set; } = default!;

    [Parameter] public AssetCreateDTO Model { get; set; } = new() { PurchaseDate = DateTime.Today, CreatedAt = DateTime.UtcNow };
    [Parameter] public bool IsEdit { get; set; } = false;
    [Parameter] public int AssetId { get; set; } = 0;

    private List<string> Currencies = new() { "RWF", "USD", "EUR" };
    private List<string> Types = new();
    private List<string> ValueChanges = new() { "Appreciate", "Depreciate", "None" };

    protected override async Task OnInitializedAsync()
    {
        var defaults = new List<string> { "Land", "Vehicle", "Stock", "Bond", "Building", "Other" };
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            if (int.TryParse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var userId))
            {
                Types = await LookupService.GetTypesAsync(userId, "AssetType", defaults);
            }
            else Types = defaults;
        }
        else Types = defaults;
    }

    private DateTime? NullablePurchaseDate
    {
        get => Model.PurchaseDate == default ? DateTime.Today : Model.PurchaseDate;
        set {
            Model.PurchaseDate = value ?? DateTime.Today;
        }
    }

    private void OnCalculateValues(string _) => CalculateCurrentValue();
    private void OnCalculateValues(DateTime? _) => CalculateCurrentValue();

    private void OnValueChangeChanged(string vc)
    {
        Model.ValueChange = vc;
        CalculateCurrentValue();
    }
    
    // Purchase value on change trigger must be handled manually since Blazor bindings don't expose onchange easily with @bind
    private decimal PurchaseValueProxy {
        get => Model.PurchaseValue;
        set { Model.PurchaseValue = value; CalculateCurrentValue(); }
    }

    private void OnTypeChanged(string type)
    {
        Model.Type = type;
        if (type == "Land")
        {
            Model.ValueChange = "Appreciate";
            Model.Rate = 15;
        }
        else if (type == "Vehicle")
        {
            Model.ValueChange = "Depreciate";
            Model.Rate = 20;
        }
        CalculateCurrentValue();
    }

    private void CalculateCurrentValue()
    {
        if (Model.ValueChange == "None" || Model.Rate == 0)
        {
            Model.CurrentValue = Model.PurchaseValue;
            return;
        }

        var daysPassed = (DateTime.Now - Model.PurchaseDate).TotalDays;
        if (daysPassed < 0) daysPassed = 0;
        
        double yearsPassed = daysPassed / 365.25;
        double rate = (double)Model.Rate / 100.0;
        double compoundMultiplier = 1.0;

        if (Model.ValueChange == "Appreciate")
        {
            compoundMultiplier = Math.Pow(1.0 + rate, yearsPassed);
        }
        else if (Model.ValueChange == "Depreciate")
        {
            compoundMultiplier = Math.Pow(1.0 - rate, yearsPassed);
            if (compoundMultiplier < 0) compoundMultiplier = 0; 
        }

        Model.CurrentValue = Model.PurchaseValue * (decimal)compoundMultiplier;
    }

    private void Submit()
    {
        OnValidSubmit();
    }

    private async void OnValidSubmit()
    {
        try
        {
            if (IsEdit)
            {
                var updateDto = new AssetUpdateDTO
                {
                    Name = Model.Name,
                    Type = Model.Type,
                    Currency = Model.Currency,
                    PurchaseValue = Model.PurchaseValue,
                    CurrentValue = Model.CurrentValue,
                    ValueChange = Model.ValueChange,
                    Rate = Model.Rate,
                    PurchaseDate = Model.PurchaseDate,
                    CreatedAt = Model.CreatedAt
                };
                await AssetService.UpdateAssetAsync(AssetId, updateDto);
                Snackbar.Add("Asset updated successfully", Severity.Success);
            }
            else
            {
                await AssetService.CreateAssetAsync(Model);
                Snackbar.Add("Asset created successfully", Severity.Success);
            }
            MudDialog?.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving asset: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => MudDialog?.Cancel();
}
