@page "/assets"
@using Application.DTO
@using Application.Interfaces
@using Domain.Entities
@using MudBlazor

@inject IAssetService AssetService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Assets</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudPaper Elevation="2" Class="pa-4">
        <div class="d-flex align-center justify-space-between mb-4">
            <MudText Typo="Typo.h5" Color="Color.Primary">Assets</MudText>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="@(()=>CreateAsset())">Add Asset</MudButton>
        </div>

        <MudTable Items="assets" Dense="true" Hover="true" Bordered="true" Striped="true" Class="mt-4" Loading="@loading" Filter="new Func<Asset,bool>(FilterFunc1)">
            <ToolBarContent>
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Category</MudTh>
                <MudTh>Purchase Value</MudTh>
                <MudTh>Current Value</MudTh>
                <MudTh>Currency</MudTh>
                <MudTh>Purchase Date</MudTh>
                <MudTh Style="width: 120px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Category">@context.Category</MudTd>
                <MudTd DataLabel="Purchase Value">@context.PurchaseValue.ToString("N2")</MudTd>
                <MudTd DataLabel="Current Value">@context.CurrentValue.ToString("N2")</MudTd>
                <MudTd DataLabel="Currency">@context.Currency?.Code</MudTd>
                <MudTd DataLabel="Purchase Date">@context.PurchaseDate.ToShortDateString()</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" OnClick="@(()=>ViewDetails(context.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(()=>EditAsset(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(()=>DeleteAsset(context.Id))" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private List<Asset> assets = new();
    private bool loading = true;
    private string searchString = "";

    private bool FilterFunc1(Asset element) => FilterFunc(element, searchString);

    private bool FilterFunc(Asset element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Category.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Currency?.Code.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            return true;
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAssets();
    }

    private async Task LoadAssets()
    {
        loading = true;
        try
        {
            assets = await AssetService.GetAllAssetsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading assets: {ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task CreateAsset()
    {
        var parameters = new DialogParameters<AssetDialog>
        {
            { x => x.Model, new AssetCreateDTO { PurchaseDate = DateTime.Today, CreatedAt = DateTime.UtcNow } },
            { x => x.IsEdit, false }
        };

        var dialog = await DialogService.ShowAsync<AssetDialog>("Add Asset", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadAssets();
        }
    }

    private async Task EditAsset(Asset asset)
    {
        var parameters = new DialogParameters<AssetDialog>
        {
            { x => x.Model, new AssetCreateDTO { 
                Name = asset.Name,
                Category = asset.Category,
                Currency = asset.Currency?.Code ?? "RWF",
                PurchaseValue = asset.PurchaseValue,
                CurrentValue = asset.CurrentValue,
                PurchaseDate = asset.PurchaseDate,
                CreatedAt = asset.CreatedAt
            } },
            { x => x.IsEdit, true },
            { x => x.AssetId, asset.Id }
        };

        var dialog = await DialogService.ShowAsync<AssetDialog>("Edit Asset", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadAssets();
        }
    }

    private void ViewDetails(int id)
    {
        Snackbar.Add("Details view open functionality can be integrated later.", Severity.Info);
    }

    private async Task DeleteAsset(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this asset?");

        if (confirmed)
        {
            try
            {
                await AssetService.DeleteAssetAsync(id);
                Snackbar.Add("Asset deleted successfully", Severity.Success);
                await LoadAssets();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting asset: {ex.Message}", Severity.Error);
            }
        }
    }
}
