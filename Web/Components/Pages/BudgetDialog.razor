@using Application.Interfaces
@using Application.DTO

@inject IBudgetService BudgetService
@inject ITransactionCategoryService CategoryService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="form">
            <MudGrid>
                @if (!IsEdit)
                {
                    <MudItem xs="12">
                        <MudSelect T="int?" Label="Category*"
                                   @bind-Value="SelectedCategoryId"
                                   Placeholder="Select a category"
                                   Required="true"
                                   AnchorOrigin="Origin.BottomCenter"
                                   Variant="Variant.Outlined">
                            @foreach (var cat in Categories)
                            {
                                <MudSelectItem T="int?" Value="@((int?)cat.Id)">@cat.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                }
                else
                {
                    <MudItem xs="12">
                        <MudTextField Value="@CategoryName"
                                      Label="Category"
                                      ReadOnly="true"
                                      Variant="Variant.Outlined"
                                      Disabled="true" />
                    </MudItem>
                }

                <MudItem xs="12">
                    <MudNumericField T="decimal"
                                     Label="Monthly Budget Amount*"
                                     @bind-Value="Amount"
                                     Required="true"
                                     Format="N0"
                                     Min="1"
                                     Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="6">
                    <MudSelect T="int?"
                               Label="Month*"
                               @bind-Value="SelectedMonth"
                               Placeholder="Select month"
                               Required="true"
                               AnchorOrigin="Origin.BottomCenter"
                               Variant="Variant.Outlined">
                        @foreach (var m in MonthOptions)
                        {
                            <MudSelectItem T="int?" Value="@m.Value">@m.Label</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6">
                    <MudSelect T="int?"
                               Label="Year*"
                               @bind-Value="SelectedYear"
                               Placeholder="Select year"
                               Required="true"
                               AnchorOrigin="Origin.BottomCenter"
                               Variant="Variant.Outlined">
                        @foreach (var y in YearOptions)
                        {
                            <MudSelectItem T="int?" Value="@y">@y</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">
            @(IsEdit ? "Update" : "Create")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public int? BudgetId { get; set; }
    [Parameter] public int CategoryId { get; set; }
    [Parameter] public decimal Amount { get; set; } = 1000;
    [Parameter] public int Month { get; set; }
    [Parameter] public int Year { get; set; }
    [Parameter] public bool IsEdit { get; set; }

    // Nullable wrappers so selects show placeholder when nothing is chosen
    private int? SelectedCategoryId;
    private int? SelectedMonth;
    private int? SelectedYear;

    private List<Domain.Entities.TransactionCategory> Categories = new();
    private MudForm form = default!;
    private string CategoryName = "";

    // Pre-built option lists to avoid Razor for-loop closure bugs
    private record MonthOption(int? Value, string Label);
    private List<MonthOption> MonthOptions = new();
    private List<int?> YearOptions = new();

    protected override async Task OnInitializedAsync()
    {
        // Build month options
        for (int m = 1; m <= 12; m++)
        {
            int monthNumber = m; // local copy to avoid closure capture issue
            MonthOptions.Add(new MonthOption(monthNumber,
                System.Globalization.DateTimeFormatInfo.CurrentInfo.GetMonthName(monthNumber)));
        }

        // Build year options (previous year → current year + 3)
        int baseYear = DateTime.Now.Year;
        for (int y = baseYear - 1; y <= baseYear + 3; y++)
        {
            int yearNumber = y; // local copy
            YearOptions.Add(yearNumber);
        }

        Categories = await CategoryService.GetAllTransactionCategoriesAsync();

        if (IsEdit)
        {
            var category = Categories.FirstOrDefault(c => c.Id == CategoryId);
            CategoryName = category?.Name ?? "Unknown";
            SelectedCategoryId = CategoryId;
        }

        // Pre-select the values passed from the parent page (if they are valid)
        SelectedMonth = Month > 0 ? Month : (int?)null;
        SelectedYear = Year > 0 ? Year : (int?)null;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        if (!IsEdit && (SelectedCategoryId == null || SelectedCategoryId <= 0))
        {
            Snackbar.Add("Please select a category.", Severity.Warning);
            return;
        }

        if (SelectedMonth == null)
        {
            Snackbar.Add("Please select a month.", Severity.Warning);
            return;
        }

        if (SelectedYear == null)
        {
            Snackbar.Add("Please select a year.", Severity.Warning);
            return;
        }

        try
        {
            if (IsEdit && BudgetId.HasValue)
            {
                await BudgetService.UpdateBudgetAsync(BudgetId.Value, new BudgetUpdateDTO
                {
                    Id = BudgetId.Value,
                    Amount = Amount,
                    Month = SelectedMonth.Value,
                    Year = SelectedYear.Value
                });
                Snackbar.Add("Budget updated successfully.", Severity.Success);
            }
            else
            {
                await BudgetService.CreateBudgetAsync(new BudgetCreateDTO
                {
                    CategoryId = SelectedCategoryId!.Value,
                    Amount = Amount,
                    Month = SelectedMonth.Value,
                    Year = SelectedYear.Value
                });
                Snackbar.Add("Budget created successfully.", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
