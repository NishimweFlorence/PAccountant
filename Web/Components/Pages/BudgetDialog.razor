@using Application.Interfaces
@using Application.DTO

@inject IBudgetService BudgetService
@inject ITransactionCategoryService CategoryService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="form" formname="BudgetForm">
            <MudGrid>
                <MudItem xs="12">
                    <MudSelect T="int?" Label="Expense Category (Optional)" @bind-Value="CategoryId" Variant="Variant.Outlined" Clearable="true">
                        <MudSelectItem T="int?" Value="null">None (General Budget)</MudSelectItem>
                        @foreach (var cat in categories.Where(c => c.Type == Domain.ValueObjects.TransactionType.Expense))
                        {
                            <MudSelectItem T="int?" Value="@cat.Id">@cat.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Name"
                                  Label="Budget Name*"
                                  Required="true"
                                  Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudNumericField T="decimal"
                                     Label="Budget Amount*"
                                     @bind-Value="Amount"
                                     Required="true"
                                     Format="N0"
                                     Min="1"
                                     Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="6">
                    <MudDatePicker Label="Start Date*"
                                   @bind-Date="StartDate"
                                   Required="true"
                                   Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="6">
                    <MudDatePicker Label="End Date*"
                                   @bind-Date="EndDate"
                                   Required="true"
                                   Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">
            @(IsEdit ? "Update" : "Create")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public int? BudgetId { get; set; }
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public decimal Amount { get; set; } = 1000;
    [Parameter] public DateTime? StartDate { get; set; }
    [Parameter] public DateTime? EndDate { get; set; }
    [Parameter] public int? CategoryId { get; set; }
    [Parameter] public bool IsEdit { get; set; }

    private MudForm form = default!;
    private List<TransactionCategory> categories = new();

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetAllTransactionCategoriesAsync();
        
        if (!IsEdit)
        {
            if (StartDate == null) StartDate = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
            if (EndDate == null) EndDate = StartDate.Value.AddMonths(1).AddDays(-1);
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.Validate();
        if (!form.IsValid) return;

        if (string.IsNullOrWhiteSpace(Name))
        {
            Snackbar.Add("Please enter a budget name.", Severity.Warning);
            return;
        }

        if (StartDate == null || EndDate == null)
        {
            Snackbar.Add("Please select start and end dates.", Severity.Warning);
            return;
        }

        try
        {
            if (IsEdit && BudgetId.HasValue)
            {
                await BudgetService.UpdateBudgetAsync(BudgetId.Value, new BudgetUpdateDTO
                {
                    Id = BudgetId.Value,
                    Name = Name,
                    Amount = Amount,
                    StartDate = StartDate.Value,
                    EndDate = EndDate.Value,
                    CategoryId = CategoryId
                });
                Snackbar.Add("Budget updated successfully.", Severity.Success);
            }
            else
            {
                await BudgetService.CreateBudgetAsync(new BudgetCreateDTO
                {
                    Name = Name,
                    Amount = Amount,
                    StartDate = StartDate.Value,
                    EndDate = EndDate.Value,
                    CategoryId = CategoryId
                });
                Snackbar.Add("Budget created successfully.", Severity.Success);
            }

            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
