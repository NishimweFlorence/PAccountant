@using Application.DTO
@using Application.Interfaces
@using Domain.ValueObjects
@using Domain.Entities
@using MudBlazor
@inject IIncomeService IncomeService
@inject IAccountService AccountService
@inject IAssetService AssetService
@inject ILookupService LookupService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddCard" Class="mr-3 mb-n1" />
            Record Income
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success" formname="IncomeForm">
            <MudGrid>
                <MudItem xs="12">
                    <MudNumericField Label="Amount" @bind-Value="Model.Amount" For="@(() => Model.Amount)" 
                                     Required="true" Format="N2" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="string" Label="Income Type" @bind-Value="Model.Type" For="@(() => Model.Type)" Required="true" Variant="Variant.Outlined">
                        @foreach (var type in IncomeTypes)
                        {
                            <MudSelectItem Value="@type">@type</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Date" @bind-Date="_modelDate" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Description" @bind-Value="Model.Description" For="@(() => Model.Description)" Required="true" Variant="Variant.Outlined" />
                </MudItem>
                
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Destination (Account or Asset)</MudText>
                    <MudDivider Class="mb-4" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSelect T="int?" Label="To Account" @bind-Value="Model.AccountId" Clearable="true" Variant="Variant.Outlined">
                        @foreach (var account in accounts)
                        {
                            <MudSelectItem Value="@((int?)account.Id)">@account.Name (@account.Balance?.ToString("N0") @account.Currency)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSelect T="int?" Label="To Asset" @bind-Value="Model.AssetId" Clearable="true" Variant="Variant.Outlined">
                        @foreach (var asset in assets)
                        {
                            <MudSelectItem Value="@((int?)asset.Id)">@asset.Name (@asset.CurrentValue.ToString("N0") @asset.Currency)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="string" Label="Currency" @bind-Value="Model.Currency" Required="true" Variant="Variant.Outlined">
                        <MudSelectItem Value="@("RWF")">RWF</MudSelectItem>
                        <MudSelectItem Value="@("USD")">USD</MudSelectItem>
                        <MudSelectItem Value="@("EUR")">EUR</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!success)">Record Income</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [CascadingParameter] private Task<Microsoft.AspNetCore.Components.Authorization.AuthenticationState> AuthStateTask { get; set; } = default!;

    private IncomeCreateDTO Model = new() { Date = DateTime.Now, Currency = "RWF", Type = "Salary" };
    private DateTime? _modelDate = DateTime.Now;
    private MudForm form = null!;
    private bool success;
    private List<Account> accounts = new();
    private List<Asset> assets = new();
    private List<string> IncomeTypes = new();

    protected override async Task OnInitializedAsync()
    {
        accounts = await AccountService.GetAllAccountsAsync();
        assets = await AssetService.GetAllAssetsAsync();
        
        var defaults = new List<string> { "Salary", "Profit on Bond", "Gift", "Other" };
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            if (int.TryParse(authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var userId))
            {
                IncomeTypes = await LookupService.GetTypesAsync(userId, "IncomeType", defaults);
            }
            else IncomeTypes = defaults;
        }
        else IncomeTypes = defaults;
    }

    private void Submit()
    {
        form.Validate();
        if (success)
        {
            if (Model.AccountId == null && Model.AssetId == null)
            {
                Snackbar.Add("Please select either an Account or an Asset as the destination.", Severity.Warning);
                return;
            }
            Model.Date = _modelDate ?? DateTime.Now;
            MudDialog.Close(DialogResult.Ok(Model));
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
