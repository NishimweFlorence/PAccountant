@page "/liabilities"
@using Application.DTO
@using Application.Interfaces
@using Domain.Entities
@using MudBlazor

@inject ILiabilityService LiabilityService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Liabilities</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudPaper Elevation="2" Class="pa-4">
        <div class="d-flex align-center justify-space-between mb-4">
            <MudText Typo="Typo.h5" Color="Color.Primary">Liabilities</MudText>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="@(()=>CreateLiability())">Add Liability</MudButton>
        </div>

        <MudTable Items="liabilities" Dense="true" Hover="true" Bordered="true" Striped="true" Class="mt-4" Loading="@loading" Filter="new Func<Liability,bool>(FilterFunc1)">
            <ToolBarContent>
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Type</MudTh>
                <MudTh>Lender Name</MudTh>
                <MudTh>Original Amount</MudTh>
                <MudTh>Current Amount</MudTh>
                <MudTh>Currency</MudTh>
                <MudTh>Due Date</MudTh>
                <MudTh Style="width: 120px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Type">@context.Type</MudTd>
                <MudTd DataLabel="Lender Name">@context.LenderName</MudTd>
                <MudTd DataLabel="Original Amount">@context.OriginalAmount.ToString("N2")</MudTd>
                <MudTd DataLabel="Current Amount">@context.CurrentAmount.ToString("N2")</MudTd>
                <MudTd DataLabel="Currency">@context.Currency?.Code</MudTd>
                <MudTd DataLabel="Due Date">@context.DueDate.ToShortDateString()</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" OnClick="@(()=>ViewDetails(context.Id))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(()=>EditLiability(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(()=>DeleteLiability(context.Id))" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private List<Liability> liabilities = new();
    private bool loading = true;
    private string searchString = "";

    private bool FilterFunc1(Liability element) => FilterFunc(element, searchString);

    private bool FilterFunc(Liability element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Type.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.LenderName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Currency?.Code.Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            return true;
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadLiabilities();
    }

    private async Task LoadLiabilities()
    {
        loading = true;
        try
        {
            liabilities = await LiabilityService.GetAllLiabilitiesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading liabilities: {ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task CreateLiability()
    {
        var parameters = new DialogParameters<LiabilityDialog>
        {
            { x => x.Model, new CreateLiabilityDTO { DueDate = DateTime.Today.AddMonths(1), CreatedAt = DateTime.UtcNow, Currency = "RWF" } },
            { x => x.IsEdit, false }
        };

        var dialog = await DialogService.ShowAsync<LiabilityDialog>("Add Liability", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadLiabilities();
        }
    }

    private async Task EditLiability(Liability liability)
    {
        var parameters = new DialogParameters<LiabilityDialog>
        {
            { x => x.Model, new CreateLiabilityDTO { 
                Type = liability.Type,
                LenderName = liability.LenderName,
                Currency = liability.Currency?.Code ?? "RWF",
                OriginalAmount = liability.OriginalAmount,
                CurrentAmount = liability.CurrentAmount,
                DueDate = liability.DueDate,
                CreatedAt = liability.CreatedAt
            } },
            { x => x.IsEdit, true },
            { x => x.LiabilityId, liability.Id }
        };

        var dialog = await DialogService.ShowAsync<LiabilityDialog>("Edit Liability", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadLiabilities();
        }
    }

    private void ViewDetails(int id)
    {
        Snackbar.Add("Details view functionality can be integrated later.", Severity.Info);
    }

    private async Task DeleteLiability(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this liability? (Note: Delete functionality needs to be added to ILiabilityService)");

        if (confirmed)
        {
            try
            {
                // Delete Liability method is missing from ILiabilityService in its current version.
                // We will inform the user about this.
                Snackbar.Add("Feature pending: LiabilityService.DeleteLiabilityAsync(id) doesn't exist yet.", Severity.Warning);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting liability: {ex.Message}", Severity.Error);
            }
        }
    }
}
