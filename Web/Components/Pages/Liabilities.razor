@page "/liabilities"
@using Application.DTO
@using Application.Interfaces
@using Domain.Entities
@using MudBlazor

@inject ILiabilityService LiabilityService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Liabilities</PageTitle>

<MudPaper Class="pa-4">
    <div style="display:flex;justify-content:space-between;align-items:center;">
        <h3>Liabilities</h3>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=>CreateLiability())">Add Liability</MudButton>
    </div>

    <MudTable Items="liabilities" Dense="true" Hover="true" Class="mt-4" Loading="@loading">
        <HeaderContent>
            <MudTh>Type</MudTh>
            <MudTh>Lender Name</MudTh>
            <MudTh>Original Amount</MudTh>
            <MudTh>Current Amount</MudTh>
            <MudTh>Currency</MudTh>
            <MudTh>Due Date</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Type">@context.Type</MudTd>
            <MudTd DataLabel="Lender Name">@context.LenderName</MudTd>
            <MudTd DataLabel="Original Amount">@context.OriginalAmount.ToString("N2")</MudTd>
            <MudTd DataLabel="Current Amount">@context.CurrentAmount.ToString("N2")</MudTd>
            <MudTd DataLabel="Currency">@context.Currency?.Code</MudTd>
            <MudTd DataLabel="Due Date">@context.DueDate.ToShortDateString()</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Info" OnClick="@(()=>ViewDetails(context.Id))" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="@(()=>EditLiability(context))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(()=>DeleteLiability(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudPaper>

@code {
    private List<Liability> liabilities = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadLiabilities();
    }

    private async Task LoadLiabilities()
    {
        loading = true;
        try
        {
            liabilities = await LiabilityService.GetAllLiabilitiesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading liabilities: {ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task CreateLiability()
    {
        var parameters = new DialogParameters<LiabilityDialog>
        {
            { x => x.Model, new CreateLiabilityDTO { DueDate = DateTime.Today.AddMonths(1), CreatedAt = DateTime.UtcNow, Currency = "RWF" } },
            { x => x.IsEdit, false }
        };

        var dialog = await DialogService.ShowAsync<LiabilityDialog>("Add Liability", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadLiabilities();
        }
    }

    private async Task EditLiability(Liability liability)
    {
        var parameters = new DialogParameters<LiabilityDialog>
        {
            { x => x.Model, new CreateLiabilityDTO { 
                Type = liability.Type,
                LenderName = liability.LenderName,
                Currency = liability.Currency?.Code ?? "RWF",
                OriginalAmount = liability.OriginalAmount,
                CurrentAmount = liability.CurrentAmount,
                DueDate = liability.DueDate,
                CreatedAt = liability.CreatedAt
            } },
            { x => x.IsEdit, true },
            { x => x.LiabilityId, liability.Id }
        };

        var dialog = await DialogService.ShowAsync<LiabilityDialog>("Edit Liability", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadLiabilities();
        }
    }

    private void ViewDetails(int id)
    {
        Snackbar.Add("Details view functionality can be integrated later.", Severity.Info);
    }

    private async Task DeleteLiability(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this liability? (Note: Delete functionality needs to be added to ILiabilityService)");

        if (confirmed)
        {
            try
            {
                // Delete Liability method is missing from ILiabilityService in its current version.
                // We will inform the user about this.
                Snackbar.Add("Feature pending: LiabilityService.DeleteLiabilityAsync(id) doesn't exist yet.", Severity.Warning);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting liability: {ex.Message}", Severity.Error);
            }
        }
    }
}
