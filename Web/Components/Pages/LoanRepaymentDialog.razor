@using MudBlazor
@using Application.DTO
@using Application.Services.Loans
@using Application.Services.LoanRepayments
@using Domain.Entities
@using Application.Interfaces
@inject ILoanService LoanService
@inject ILoanRepaymentService LoanRepaymentService
@inject IAccountService AccountService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="form" @bind-IsValid="@success" formname="LoanRepaymentForm">
            <MudSelect T="int" Label="Select Loan" @bind-Value="Model.LoanId" Required="true" RequiredError="Loan is required!" Placeholder="Select Loan">
                @if (Loans != null)
                {
                    @foreach (var loan in Loans)
                    {
                        <MudSelectItem Value="@loan.Id">@loan.Borrower - Total to Pay: @loan.AmountToPay.ToString("N2") (@loan.Currency)</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudSelect T="int" Label="Destination Account" @bind-Value="Model.AccountId" Required="true" RequiredError="Account is required!" Placeholder="Destination Account">
                @if (Accounts != null)
                {
                    @foreach (var account in Accounts)
                    {
                        <MudSelectItem Value="@account.Id">@account.Name (@account.AccountNumber) - Balance: @account.Balance @account.Currency?.Symbol</MudSelectItem>
                    }
                }
            </MudSelect>
            <MudNumericField T="decimal" Label="Amount" @bind-Value="Model.Amount" Required="true" RequiredError="Amount is required!" Min="0.01m" Placeholder="Amount" />
            <MudDatePicker Label="Repayment Date" @bind-Date="Model.RepaymentDate" Required="true" RequiredError="Date is required!" Placeholder="Repayment Date" />
            <MudTextField T="string" Label="Note" @bind-Value="Model.Note" Lines="3" Placeholder="Note" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Disabled="@(!success)" OnClick="Submit">@ButtonText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public LoanRepaymentUpdateDTO Model { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }

    private string ButtonText => IsEdit ? "Update" : "Add";
    private bool success;
    private MudForm form = new();
    private List<LoanCreateDTO> Loans = new();
    private List<Account> Accounts = new();

    protected override async Task OnInitializedAsync()
    {
        Loans = await LoanService.GetAllLoansAsync();
        Accounts = await AccountService.GetAllAccountsAsync();
        if (!IsEdit)
        {
            Model.RepaymentDate = DateTime.Today;
        }
    }

    private void Cancel() => MudDialog?.Cancel();

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            try
            {
                if (IsEdit)
                {
                    await LoanRepaymentService.UpdateLoanRepaymentAsync(Model);
                    Snackbar.Add("Repayment updated successfully", Severity.Success);
                }
                else
                {
                    var createDto = new LoanRepaymentCreateDTO
                    {
                        LoanId = Model.LoanId,
                        AccountId = Model.AccountId,
                        Amount = Model.Amount,
                        RepaymentDate = Model.RepaymentDate ?? DateTime.Now,
                        Note = Model.Note
                    };
                    await LoanRepaymentService.CreateLoanRepaymentAsync(createDto);
                    Snackbar.Add("Repayment added successfully", Severity.Success);
                }
                MudDialog?.Close(DialogResult.Ok(true));
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }
}
