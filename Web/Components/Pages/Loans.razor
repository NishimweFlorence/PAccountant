@page "/loans"
@using Application.DTO
@using Application.Services.Loans
@using Application.Interfaces
@using MudBlazor

@inject ILoanService LoanService
@inject ILoanRepaymentService LoanRepaymentService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Loans</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6" @bind-ActivePanelIndex="_activeTab">
        <MudTabPanel Text="Loans" Icon="@Icons.Material.Filled.AccountBalanceWallet">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h5" Color="Color.Primary">Loans</MudText>
                <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="@(()=>CreateLoan())">Add Loan</MudButton>
            </div>

            <MudTable Items="loans" Dense="true" Hover="true" Bordered="true" Striped="true" Class="mt-4" Loading="@loadingLoans" Filter="new Func<LoanCreateDTO,bool>(FilterFuncLoan)">
                <ToolBarContent>
                    <MudSpacer />
                    <MudTextField @bind-Value="searchStringLoan" Placeholder="Search Loans" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Borrower</MudTh>
                    <MudTh>Amount</MudTh>
                    <MudTh>Currency</MudTh>
                    <MudTh>Rate (%)</MudTh>
                    <MudTh>Total to Pay</MudTh>
                    <MudTh>Date</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="width: 150px;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Borrower">@context.Borrower</MudTd>
                    <MudTd DataLabel="Amount">@context.Amount.ToString("N2")</MudTd>
                    <MudTd DataLabel="Currency">@context.Currency</MudTd>
                    <MudTd DataLabel="Rate">@context.InterestRate.ToString("0.##")%</MudTd>
                    <MudTd DataLabel="Total">@context.AmountToPay.ToString("N2")</MudTd>
                    <MudTd DataLabel="Date">@context.LoanDate?.ToShortDateString()</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                    </MudTd>
                    <MudTd>
                        <MudTooltip Text="Add Repayment">
                            <MudIconButton Icon="@Icons.Material.Filled.Payments" Color="Color.Success" Size="Size.Small" OnClick="@(()=>CreateRepayment(context))" />
                        </MudTooltip>
                        <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" OnClick="@(()=>ViewDetails(context.Id))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(()=>EditLoan(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(()=>DeleteLoan(context.Id))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>

        <MudTabPanel Text="Repayments" Icon="@Icons.Material.Filled.History">
            <div class="d-flex align-center justify-space-between mb-4">
                <MudText Typo="Typo.h5" Color="Color.Primary">Loan Repayments</MudText>
                <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="OpenAddRepaymentDialog">Add Repayment</MudButton>
            </div>

            <MudTable Items="@repayments" Dense="true" Hover="true" Bordered="true" Striped="true" Loading="@loadingRepayments" Filter="new Func<LoanRepaymentCreateDTO,bool>(FilterFuncRepayment)">
                <ToolBarContent>
                    <MudSpacer />
                    <MudTextField @bind-Value="searchStringRepayment" Placeholder="Search Repayments" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Loan / Borrower</MudTh>
                    <MudTh>Amount</MudTh>
                    <MudTh>Date</MudTh>
                    <MudTh>Note</MudTh>
                    <MudTh Style="width: 120px;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Loan / Borrower">@GetLoanInfo(context.LoanId)</MudTd>
                    <MudTd DataLabel="Amount">@context.Amount.ToString("N2")</MudTd>
                    <MudTd DataLabel="Date">@context.RepaymentDate?.ToShortDateString()</MudTd>
                    <MudTd DataLabel="Note">@context.Note</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Info" Size="Size.Small" OnClick="@(() => OpenEditRepaymentDialog(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => DeleteRepayment(context))" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager />
                </PagerContent>
            </MudTable>
        </MudTabPanel>
    </MudTabs>
</MudContainer>

@code {
    private List<LoanCreateDTO> loans = new();
    private List<LoanRepaymentCreateDTO> repayments = new();
    private bool loadingLoans = true;
    private bool loadingRepayments = true;
    private string searchStringLoan = "";
    private string searchStringRepayment = "";
    private int _activeTab = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        await LoadLoans();
        await LoadRepayments();
    }

    private async Task LoadLoans()
    {
        loadingLoans = true;
        try
        {
            loans = await LoanService.GetAllLoansAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading loans: {ex.Message}", Severity.Error);
        }
        finally
        {
            loadingLoans = false;
        }
    }

    private async Task LoadRepayments()
    {
        loadingRepayments = true;
        try
        {
            repayments = await LoanRepaymentService.GetAllLoanRepaymentsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading repayments: {ex.Message}", Severity.Error);
        }
        finally
        {
            loadingRepayments = false;
        }
    }

    private bool FilterFuncLoan(LoanCreateDTO element)
    {
        if (string.IsNullOrWhiteSpace(searchStringLoan))
            return true;
        if (element.Borrower.Contains(searchStringLoan, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Currency.Contains(searchStringLoan, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Status.Contains(searchStringLoan, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private bool FilterFuncRepayment(LoanRepaymentCreateDTO element)
    {
        if (string.IsNullOrWhiteSpace(searchStringRepayment))
            return true;
        if (GetLoanInfo(element.LoanId).Contains(searchStringRepayment, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Note?.Contains(searchStringRepayment, StringComparison.OrdinalIgnoreCase) ?? false)
            return true;
        if (element.Amount.ToString().Contains(searchStringRepayment, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    private string GetLoanInfo(int loanId)
    {
        var loan = loans.FirstOrDefault(l => l.Id == loanId);
        return loan != null ? $"{loan.Borrower} (#{loan.Id})" : $"Loan #{loanId}";
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Paid" => Color.Info,
        "Overdue" => Color.Error,
        _ => Color.Default
    };

    private async Task CreateLoan()
    {
        var parameters = new DialogParameters<LoanDialog>
        {
            { x => x.Model, new LoanCreateDTO { LoanDate = DateTime.Today, Status = "Active" } },
            { x => x.IsEdit, false }
        };

        var dialog = await DialogService.ShowAsync<LoanDialog>("Add Loan", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadLoans();
        }
    }

    private async Task EditLoan(LoanCreateDTO loan)
    {
        var parameters = new DialogParameters<LoanDialog>
        {
            { x => x.Model, loan },
            { x => x.IsEdit, true }
        };

        var dialog = await DialogService.ShowAsync<LoanDialog>("Edit Loan", parameters);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadLoans();
        }
    }

    private async Task CreateRepayment(LoanCreateDTO loan)
    {
        var parameters = new DialogParameters<LoanRepaymentDialog>
        {
            { x => x.Model, new LoanRepaymentUpdateDTO { LoanId = loan.Id, RepaymentDate = DateTime.Today } },
            { x => x.IsEdit, false }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<LoanRepaymentDialog>("Add Repayment", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadData();
            _activeTab = 1; // Switch to repayments tab
        }
    }

    private async Task OpenAddRepaymentDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<LoanRepaymentDialog>("Add New Repayment", options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadRepayments();
        }
    }

    private async Task OpenEditRepaymentDialog(LoanRepaymentCreateDTO item)
    {
        var parameters = new DialogParameters<LoanRepaymentDialog>
        {
            { x => x.IsEdit, true },
            { x => x.Model, new LoanRepaymentUpdateDTO
                {
                    Id = item.Id,
                    LoanId = item.LoanId,
                    Amount = item.Amount,
                    RepaymentDate = item.RepaymentDate,
                    Note = item.Note,
                    AccountId = item.AccountId
                }
            }
        };

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<LoanRepaymentDialog>("Edit Repayment", parameters, options);
        var result = await dialog.Result;

        if (result != null && !result.Canceled)
        {
            await LoadRepayments();
        }
    }

    private async Task DeleteRepayment(LoanRepaymentCreateDTO item)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this repayment?");

        if (confirmed)
        {
            try
            {
                await LoanRepaymentService.DeleteLoanRepaymentAsync(new LoanRepaymentDeleteDTO { Id = item.Id });
                Snackbar.Add("Repayment deleted successfully", Severity.Success);
                await LoadRepayments();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private void ViewDetails(int id)
    {
        Navigation.NavigateTo($"/loans/{id}");
    }

    private async Task DeleteLoan(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this loan?");

        if (confirmed)
        {
            try
            {
                await LoanService.DeleteLoanAsync(new LoanDeleteDTO { Id = id });
                Snackbar.Add("Loan deleted successfully", Severity.Success);
                await LoadLoans();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting loan: {ex.Message}", Severity.Error);
            }
        }
    }
}
