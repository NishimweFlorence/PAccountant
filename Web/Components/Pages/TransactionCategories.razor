@using Domain.Entities
@using Application.Interfaces
@using Application.DTO
@rendermode InteractiveServer

@inject ITransactionCategoryService TransactionCategoryService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

@page "/TransactionCategories"

<PageTitle>Transaction Categories</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudPaper Elevation="2" Class="pa-4">
        <div class="d-flex align-center justify-space-between mb-4">
            <MudText Typo="Typo.h5" Color="Color.Primary">Transaction Categories</MudText>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="@(()=>CreateCategory())">Add Category</MudButton>
        </div>

        <MudTable Items="transactionCategories" Dense="true" Hover="true" Bordered="true" Striped="true" Class="mt-4" Loading="@loading" Filter="new Func<TransactionCategory,bool>(FilterFunc1)">
            <ToolBarContent>
                <MudSpacer />
                <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Id</MudTh>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh Style="width: 120px;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Id">@context.Id</MudTd>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Type">@context.Type?.ToString()</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" OnClick="@(()=>Navigation.NavigateTo($"/transactionCategories/{context.Id}"))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(()=>EditCategory(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(()=>DeleteCategory(context.Id))" />
                </MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    List<Domain.Entities.TransactionCategory> transactionCategories = new();
    private bool loading = true;
    private string searchString = "";

    private bool FilterFunc1(TransactionCategory element) => FilterFunc(element, searchString);

    private bool FilterFunc(TransactionCategory element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Type?.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            return true;
        return false;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        loading = true;
        try
        {
            transactionCategories = await TransactionCategoryService.GetAllTransactionCategoriesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading categories: {ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }

    private async Task CreateCategory()
    {
        var parameters = new DialogParameters<TransactionCategoryDialog>
        {
            { x => x.Model, new TransactionCategoryCreateDTO() },
            { x => x.IsEdit, false }
        };

        var dialog = await DialogService.ShowAsync<TransactionCategoryDialog>("Add Category", parameters);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled)
        {
            await LoadCategories();
        }
    }

    private async Task EditCategory(TransactionCategory category)
    {
        var parameters = new DialogParameters<TransactionCategoryDialog>
        {
            { x => x.Model, new TransactionCategoryCreateDTO { 
                Name = category.Name, 
                Type = category.Type?.ToString() 
            } },
            { x => x.IsEdit, true },
            { x => x.CategoryId, category.Id }
        };

        var dialog = await DialogService.ShowAsync<TransactionCategoryDialog>("Edit Category", parameters);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled)
        {
            await LoadCategories();
        }
    }

    private async Task DeleteCategory(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this category?");

        if (confirmed)
        {
            try
            {
                // Note: Delete method assumed from flow pattern
                Snackbar.Add("Feature coming soon: Delete Category", Severity.Info);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error deleting category: {ex.Message}", Severity.Error);
            }
        }
    }
}
