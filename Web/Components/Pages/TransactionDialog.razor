@using Application.DTO
@using System.ComponentModel.DataAnnotations
@using Domain.Entities
@using Application.Interfaces
@using MudBlazor

@inject ITransactionService TransactionService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(IsEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.Add)" Class="mr-2 mb-n1" />
            @(IsEdit ? "Edit Transaction" : "New Transaction")
        </MudText>
    </TitleContent>
    <DialogContent>
        <EditForm Model="@Model" OnValidSubmit="SubmitForm" FormName="TransactionDialogForm">
            <DataAnnotationsValidator />
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Transaction Date"
                                   Date="@Model.TransactionDate"
                                   DateChanged="@((DateTime? d) => Model.TransactionDate = d ?? DateTime.Today)"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Editable="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string"
                               @bind-Value="Model.Currency"
                               Label="Currency"
                               Variant="Variant.Outlined"
                               Required="true">
                        @foreach (var c in Currencies)
                        {
                            <MudSelectItem T="string" Value="@c">@c</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Description" Label="Description" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.ReferenceNumber" Label="Reference Number" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle1"><b>Entries</b></MudText>
                    @foreach (var entry in Model.Entries)
                    {
                        <div class="d-flex gap-2 mb-2 align-center">
                            <MudSelect T="int?" @bind-Value="entry.AccountId" Label="Account" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="int?" Value="@((int?)null)">None</MudSelectItem>
                                @foreach (var acc in Accounts) { <MudSelectItem T="int?" Value="@acc.Id">@acc.Name</MudSelectItem> }
                            </MudSelect>
                            <MudSelect T="int?" @bind-Value="entry.CategoryId" Label="Category" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="int?" Value="@((int?)null)">None</MudSelectItem>
                                @foreach (var cat in TransactionCategories) { <MudSelectItem T="int?" Value="@cat.Id">@cat.Name</MudSelectItem> }
                            </MudSelect>
                            <MudNumericField T="decimal" @bind-Value="entry.Debit" Label="Debit" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                            <MudNumericField T="decimal" @bind-Value="entry.Credit" Label="Credit" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => Model.Entries.Remove(entry))" />
                        </div>
                    }
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Text" OnClick="@(() => Model.Entries.Add(new TransactionEntryDTO()))">Add Entry</MudButton>
                </MudItem>
            </MudGrid>
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitForm">@(IsEdit ? "Update" : "Save")</MudButton>
    </DialogActions>
</MudDialog>

@code{
    [CascadingParameter] IMudDialogInstance DialogInstance { get; set; } = default!;

    [Parameter] public CreateTransactionDTO Model { get; set; } = new() { Entries = new List<TransactionEntryDTO>() };
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public int TransactionId { get; set; }
    [Parameter] public List<TransactionCategory> TransactionCategories { get; set; } = new();
    [Parameter] public List<Account> Accounts { get; set; } = new();
    [Parameter] public List<string> Currencies { get; set; } = new();

    private async Task SubmitForm()
    {
        try
        {
            if (Model.Entries == null || !Model.Entries.Any())
            {
                Snackbar.Add("Please add at least one entry.", Severity.Warning);
                return;
            }

            var totalDebit = Model.Entries.Sum(e => e.Debit);
            var totalCredit = Model.Entries.Sum(e => e.Credit);
            
            if (totalDebit != totalCredit)
            {
                Snackbar.Add($"Transaction unbalanced! Debits: {totalDebit}, Credits: {totalCredit}. Difference: {Math.Abs(totalDebit - totalCredit)}", Severity.Warning);
                return;
            }

            if (totalDebit <= 0)
            {
                Snackbar.Add("Transaction amount must be greater than zero.", Severity.Warning);
                return;
            }

            if (IsEdit)
            {
                var updateDto = new UpdateTransactionDTO
                {
                    Description = Model.Description,
                    ReferenceNumber = Model.ReferenceNumber,
                    BudgetId = Model.BudgetId,
                    Currency = Model.Currency,
                    TransactionDate = Model.TransactionDate,
                    Entries = Model.Entries
                };
                await TransactionService.UpdateTransactionAsync(TransactionId, updateDto);
                Snackbar.Add("Transaction updated successfully!", Severity.Success);
            }
            else
            {
                Model.CreatedAt = DateTime.Now;
                await TransactionService.CreateTransactionAsync(Model);
                Snackbar.Add("Transaction created successfully!", Severity.Success);
            }
            DialogInstance.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void Cancel() => DialogInstance.Cancel();
}

